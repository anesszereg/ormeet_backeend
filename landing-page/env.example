# Main React App URL

# Development with Nginx (Recommended)
NEXT_PUBLIC_APP_URL=http://localhost

# Development without Nginx (Direct access)
# NEXT_PUBLIC_APP_URL=http://localhost:5173

# Production (update with your actual domain)
# NEXT_PUBLIC_APP_URL=https://ormeet.com
# or
# NEXT_PUBLIC_APP_URL=https://app.ormeet.com
